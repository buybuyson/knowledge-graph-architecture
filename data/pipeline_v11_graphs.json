  "data_flow": {
    "schema": {
      "node_types": [
        "DataState"
      ],
      "edge_types": [
        "reads",
        "replaces",
        "derives",
        "edits",
        "annotates",
        "emits"
      ]
    },
    "nodes": [
      {
        "id": "d:raw",
        "type": "DataState",
        "label": "Raw audio (original file)",
        "kind": "audio",
        "props": {
          "mutable": false,
          "on_disk": true,
          "note": "source file provided by the user"
        }
      },
      {
        "id": "d:validated",
        "type": "DataState",
        "label": "Validated audio",
        "kind": "audio_meta",
        "props": {
          "mutable": false,
          "derived_from": "d:raw",
          "note": "only metadata added (duration/format), audio unchanged"
        }
      },
      {
        "id": "d:denoised",
        "type": "DataState",
        "label": "Denoised audio",
        "kind": "audio",
        "props": {
          "mutable": false,
          "reversible": false,
          "lossy": true,
          "derived_from": "d:validated",
          "note": "audio data replaced; original kept separately, this step itself is not recoverable"
        }
      },
      {
        "id": "d:chunkwav",
        "type": "DataState",
        "label": "WAV of 1 chunk",
        "kind": "audio",
        "props": {
          "mutable": false,
          "derived_from": "d:denoised",
          "note": "cut one segment by time window"
        }
      },
      {
        "id": "d:segs_raw",
        "type": "DataState",
        "label": "Raw segments",
        "kind": "segments",
        "props": {
          "mutable": true,
          "derived_from": "d:chunkwav",
          "fields": [
            "start",
            "end",
            "text"
          ],
          "note": "timestamp relative to chunk origin, not yet shifted to the original file"
        }
      },
      {
        "id": "d:segs_shift",
        "type": "DataState",
        "label": "Timestamp-shifted segments",
        "kind": "segments",
        "props": {
          "mutable": true,
          "reversible": true,
          "derived_from": "d:segs_raw",
          "note": "only start/end change (+= chunk_start); text unchanged"
        }
      },
      {
        "id": "d:segs_llm",
        "type": "DataState",
        "label": "LLM-corrected segments",
        "kind": "segments",
        "props": {
          "mutable": true,
          "reversible": false,
          "lossy": true,
          "derived_from": "d:segs_shift",
          "fields_changed": [
            "text"
          ],
          "note": "LLM edits text; risk of hallucination/line deletion — this characteristic belongs to the data state, not the edge"
        }
      },
      {
        "id": "d:segs_spk",
        "type": "DataState",
        "label": "Segments with speaker",
        "kind": "segments",
        "props": {
          "mutable": true,
          "derived_from": "d:segs_llm",
          "fields_added": [
            "speaker"
          ],
          "note": "add speaker label, text/timestamp unchanged"
        }
      },
      {
        "id": "d:part",
        "type": "DataState",
        "label": "_partNN.docx/srt file",
        "kind": "file",
        "props": {
          "on_disk": true,
          "derived_from": "d:segs_spk",
          "note": "export each chunk to disk"
        }
      },
      {
        "id": "d:final",
        "type": "DataState",
        "label": "Final file (merged)",
        "kind": "file",
        "props": {
